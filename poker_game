<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Finopoly Poker – Bot vs Human</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --felt: #1a4731;
    --felt-light: #205a3c;
    --felt-dark: #0f2d1f;
    --gold: #c9a84c;
    --gold-light: #f0d07a;
    --cream: #f5ede0;
    --red: #c0392b;
    --red-light: #e74c3c;
    --chip-blue: #2980b9;
    --chip-white: #ecf0f1;
    --chip-black: #2c3e50;
    --text-light: #f5ede0;
    --shadow: rgba(0,0,0,0.5);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Space Mono', monospace;
    background: radial-gradient(ellipse at center, #0f2d1f 0%, #060f0a 100%);
    min-height: 100vh;
    color: var(--cream);
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      repeating-linear-gradient(45deg, transparent, transparent 2px, rgba(255,255,255,0.01) 2px, rgba(255,255,255,0.01) 4px);
    pointer-events: none;
    z-index: 0;
  }

  .screen { display: none; position: relative; z-index: 1; }
  .screen.active { display: flex; flex-direction: column; min-height: 100vh; }

  .header {
    text-align: center;
    padding: 24px 16px 8px;
  }
  .header h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 900;
    color: var(--gold);
    text-shadow: 0 2px 12px rgba(201,168,76,0.4), 0 0 40px rgba(201,168,76,0.15);
    letter-spacing: 2px;
  }
  .header .subtitle {
    color: rgba(245,237,224,0.5);
    font-size: 0.7rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .divider {
    height: 2px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
    margin: 8px 48px;
    opacity: 0.5;
  }

  #setup {
    align-items: center;
    justify-content: flex-start;
    padding-bottom: 40px;
  }

  .setup-card {
    background: rgba(32,90,60,0.5);
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 16px;
    padding: 32px;
    margin: 16px;
    max-width: 600px;
    width: calc(100% - 32px);
    backdrop-filter: blur(8px);
  }

  .setup-card h2 {
    font-family: 'Playfair Display', serif;
    color: var(--gold);
    font-size: 1.3rem;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .rules-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 8px;
  }
  @media(max-width:500px){ .rules-grid { grid-template-columns: 1fr; } }

  .rule-item {
    background: rgba(15,45,31,0.6);
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 0.72rem;
    line-height: 1.5;
  }
  .rule-item .rank {
    color: var(--gold);
    font-weight: 700;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: block;
    margin-bottom: 3px;
  }

  .scoring-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.68rem;
    margin-top: 8px;
  }
  .scoring-table th {
    background: rgba(201,168,76,0.2);
    color: var(--gold);
    padding: 6px 8px;
    text-align: left;
    font-weight: 700;
    letter-spacing: 1px;
  }
  .scoring-table td {
    padding: 5px 8px;
    border-bottom: 1px solid rgba(201,168,76,0.08);
    color: rgba(245,237,224,0.8);
  }
  .scoring-table tr:nth-child(even) td { background: rgba(255,255,255,0.03); }
  .pos { color: #2ecc71; font-weight: 700; }
  .neg { color: #e74c3c; font-weight: 700; }

  .rounds-selector {
    display: flex;
    align-items: center;
    gap: 16px;
    justify-content: center;
    margin: 20px 0;
    flex-wrap: wrap;
  }
  .rounds-selector label {
    font-size: 0.8rem;
    color: var(--gold);
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .rounds-input {
    background: rgba(15,45,31,0.8);
    border: 1px solid var(--gold);
    border-radius: 8px;
    color: var(--cream);
    font-family: 'Space Mono', monospace;
    font-size: 1.1rem;
    padding: 8px 16px;
    width: 80px;
    text-align: center;
  }
  .rounds-input:focus { outline: none; border-color: var(--gold-light); box-shadow: 0 0 12px rgba(201,168,76,0.3); }

  .btn {
    cursor: pointer;
    border: none;
    border-radius: 10px;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: all 0.2s;
    padding: 14px 32px;
    font-size: 0.8rem;
  }
  .btn-gold {
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);
    color: #1a1a1a;
    box-shadow: 0 4px 20px rgba(201,168,76,0.35);
  }
  .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(201,168,76,0.5); }
  .btn-gold:active { transform: translateY(0); }

  #game {
    align-items: stretch;
    padding: 0 0 40px;
  }

  .scoreboard {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(15,45,31,0.9);
    border-bottom: 2px solid rgba(201,168,76,0.3);
    padding: 12px 20px;
    gap: 12px;
    flex-wrap: wrap;
  }
  .score-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 80px;
  }
  .score-label {
    font-size: 0.6rem;
    color: rgba(245,237,224,0.5);
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .score-value {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
  }
  .score-value.positive { color: #2ecc71; }
  .score-value.negative { color: #e74c3c; }
  .round-info {
    font-size: 0.65rem;
    color: rgba(245,237,224,0.6);
    text-align: center;
    letter-spacing: 2px;
  }
  .round-info strong { color: var(--cream); font-size: 1rem; font-family: 'Playfair Display', serif; }

  .table-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px 16px;
    gap: 24px;
  }

  .player-zone {
    width: 100%;
    max-width: 560px;
  }

  .zone-label {
    font-size: 0.6rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(245,237,224,0.4);
    margin-bottom: 10px;
    text-align: center;
  }

  .cards-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .card {
    width: 80px;
    height: 112px;
    border-radius: 10px;
    background: white;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 6px 8px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.8);
    position: relative;
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .card.red-card { color: #c0392b; }
  .card.black-card { color: #1a1a2e; }
  .card.hidden-card {
    background: linear-gradient(135deg, #1a4731 25%, #205a3c 50%, #1a4731 75%);
    background-size: 8px 8px;
  }
  .card.community-card {
    width: 90px;
    height: 126px;
    border: 3px solid var(--gold);
    box-shadow: 0 6px 30px rgba(201,168,76,0.4), 0 0 0 1px rgba(201,168,76,0.2);
  }
  .card.revealed { animation: flipIn 0.4s ease; }
  @keyframes flipIn {
    0% { transform: rotateY(90deg) scale(0.9); opacity: 0; }
    100% { transform: rotateY(0deg) scale(1); opacity: 1; }
  }

  .card-corner { display: flex; flex-direction: column; align-items: center; line-height: 1; }
  .card-rank { font-size: 1rem; font-weight: 900; font-family: 'Playfair Display', serif; }
  .card-suit { font-size: 0.75rem; }
  .card-center { font-size: 2rem; text-align: center; }
  .card-corner.bottom { transform: rotate(180deg); align-self: flex-end; }

  .hidden-pattern {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    padding: 8px 6px;
    height: 100%;
  }
  .hidden-pattern span {
    background: rgba(201,168,76,0.3);
    border-radius: 3px;
    display: block;
  }

  .community-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .community-label {
    font-size: 0.6rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold);
    opacity: 0.8;
  }

  .action-area {
    width: 100%;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .action-buttons {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 12px;
    width: 100%;
  }

  .btn-action {
    padding: 14px 8px;
    border-radius: 12px;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .btn-action:disabled { opacity: 0.4; cursor: not-allowed; transform: none !important; }
  .btn-action .action-icon { font-size: 1.3rem; }
  .btn-action .action-pts { font-size: 0.55rem; color: rgba(255,255,255,0.6); letter-spacing: 1px; font-weight: 400; }

  .btn-fold {
    background: rgba(192,57,43,0.2);
    border-color: rgba(192,57,43,0.5);
    color: #e74c3c;
  }
  .btn-fold:hover:not(:disabled) { background: rgba(192,57,43,0.4); border-color: #e74c3c; transform: translateY(-2px); }

  .btn-call {
    background: rgba(41,128,185,0.2);
    border-color: rgba(41,128,185,0.5);
    color: #3498db;
  }
  .btn-call:hover:not(:disabled) { background: rgba(41,128,185,0.4); border-color: #3498db; transform: translateY(-2px); }

  .btn-raise {
    background: rgba(201,168,76,0.2);
    border-color: rgba(201,168,76,0.5);
    color: var(--gold);
  }
  .btn-raise:hover:not(:disabled) { background: rgba(201,168,76,0.4); border-color: var(--gold); transform: translateY(-2px); }

  .btn-quit {
    background: transparent;
    border: 1px solid rgba(245,237,224,0.2);
    color: rgba(245,237,224,0.4);
    padding: 8px 20px;
    border-radius: 8px;
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-quit:hover { border-color: rgba(245,237,224,0.5); color: rgba(245,237,224,0.7); }

  .result-panel {
    width: 100%;
    max-width: 560px;
    background: rgba(15,45,31,0.9);
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 14px;
    padding: 20px;
    text-align: center;
    display: none;
    animation: slideUp 0.3s ease;
  }
  .result-panel.show { display: block; }
  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .result-headline {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .result-headline.win { color: #2ecc71; }
  .result-headline.lose { color: #e74c3c; }
  .result-headline.tie { color: var(--gold); }

  .result-details {
    font-size: 0.7rem;
    color: rgba(245,237,224,0.6);
    margin-bottom: 16px;
    line-height: 1.8;
  }
  .result-details .hand-name { color: var(--cream); font-weight: 700; }

  .bot-reveal {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin: 12px 0;
    flex-wrap: wrap;
  }

  .score-delta {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin: 12px 0;
    font-size: 0.8rem;
  }
  .delta-item { display: flex; flex-direction: column; align-items: center; gap: 2px; }
  .delta-label { font-size: 0.55rem; letter-spacing: 2px; color: rgba(245,237,224,0.4); }
  .delta-val { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; }
  .delta-val.pos { color: #2ecc71; }
  .delta-val.neg { color: #e74c3c; }
  .delta-val.zero { color: rgba(245,237,224,0.4); }

  .btn-next {
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
    color: #1a1a1a;
    border: none;
    border-radius: 10px;
    padding: 12px 28px;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 4px;
  }
  .btn-next:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(201,168,76,0.4); }

  #end {
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
  }
  .end-card {
    background: rgba(32,90,60,0.5);
    border: 1px solid rgba(201,168,76,0.4);
    border-radius: 20px;
    padding: 40px 32px;
    max-width: 480px;
    width: 100%;
    text-align: center;
    backdrop-filter: blur(8px);
  }
  .end-trophy { font-size: 3.5rem; margin-bottom: 12px; }
  .end-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: var(--gold);
    margin-bottom: 8px;
  }
  .end-subtitle { color: rgba(245,237,224,0.5); font-size: 0.7rem; letter-spacing: 2px; margin-bottom: 28px; }
  .end-scores {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-bottom: 28px;
  }
  .end-score-block { display: flex; flex-direction: column; align-items: center; }
  .end-score-label { font-size: 0.6rem; letter-spacing: 2px; color: rgba(245,237,224,0.4); margin-bottom: 6px; }
  .end-score-val { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 900; color: var(--gold); }

  .toast {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: rgba(15,45,31,0.95);
    border: 1px solid var(--gold);
    color: var(--cream);
    padding: 10px 24px;
    border-radius: 100px;
    font-size: 0.7rem;
    letter-spacing: 1px;
    z-index: 100;
    transition: transform 0.3s;
    pointer-events: none;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 200;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.show { display: flex; }
  .modal-box {
    background: #0f2d1f;
    border: 1px solid var(--gold);
    border-radius: 16px;
    padding: 32px;
    max-width: 360px;
    width: 90%;
    text-align: center;
  }
  .modal-box h3 { font-family: 'Playfair Display', serif; color: var(--gold); font-size: 1.3rem; margin-bottom: 12px; }
  .modal-box p { font-size: 0.75rem; color: rgba(245,237,224,0.6); margin-bottom: 24px; line-height: 1.7; }
  .modal-buttons { display: flex; gap: 12px; justify-content: center; }
  .btn-resume { background: transparent; border: 1px solid rgba(245,237,224,0.3); color: rgba(245,237,224,0.7); padding: 10px 20px; border-radius: 8px; font-family: 'Space Mono', monospace; font-size: 0.7rem; cursor: pointer; }
  .btn-end-game { background: var(--red); border: none; color: white; padding: 10px 20px; border-radius: 8px; font-family: 'Space Mono', monospace; font-size: 0.7rem; font-weight: 700; cursor: pointer; }

  /* Sound toggle button */
  .sound-toggle {
    position: fixed;
    top: 12px;
    right: 16px;
    z-index: 300;
    background: rgba(15,45,31,0.85);
    border: 1px solid rgba(201,168,76,0.4);
    border-radius: 8px;
    color: var(--gold);
    font-size: 1.1rem;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
  }
  .sound-toggle:hover { background: rgba(32,90,60,0.9); }
  .sound-toggle.muted { opacity: 0.45; }
</style>
</head>
<body>

<!-- Sound toggle -->
<div class="sound-toggle" id="soundToggle" title="Toggle sound" onclick="toggleSound()">🔊</div>

<!-- ── SETUP SCREEN ── -->
<div id="setup" class="screen active">
  <div class="header">
    <h1>♠ FINOPOLY POKER ♠</h1>
    <div class="subtitle">Bot vs Human · 3-Card Edition</div>
    <div class="divider"></div>
  </div>

  <div class="setup-card">
    <h2>📋 Hand Rankings <span style="font-size:0.7rem;color:rgba(245,237,224,0.4);font-family:'Space Mono',monospace;">(highest → lowest)</span></h2>
    <div class="rules-grid">
      <div class="rule-item"><span class="rank">① Straight Flush</span>3 same-suit sequential cards. Tie: higher top card wins. A-2-3 is lowest.</div>
      <div class="rule-item"><span class="rank">② Three of a Kind</span>3 cards of same rank. Tie: higher rank wins.</div>
      <div class="rule-item"><span class="rank">③ Straight</span>3 sequential cards, mixed suits. Tie: higher top card wins.</div>
      <div class="rule-item"><span class="rank">④ Flush</span>3 same-suit cards, not sequential. Tie: compare cards top-down.</div>
      <div class="rule-item"><span class="rank">⑤ Pair</span>2 cards same rank + kicker. Tie: higher pair, then higher kicker.</div>
      <div class="rule-item"><span class="rank">⑥ High Card</span>None of the above. Tie: compare cards top-down.</div>
    </div>
  </div>

  <div class="setup-card">
    <h2>🎲 Scoring Table</h2>
    <table class="scoring-table">
      <tr><th>You</th><th>Bot</th><th>Outcome</th><th>Your Pts</th><th>Bot Pts</th></tr>
      <tr><td>FOLD</td><td>FOLD</td><td>Both forfeit</td><td class="zero">0</td><td class="zero">0</td></tr>
      <tr><td>CALL</td><td>FOLD</td><td>Bot forfeits, you win</td><td class="pos">+2</td><td class="neg">−1</td></tr>
      <tr><td>FOLD</td><td>CALL/RAISE</td><td>You forfeit, bot wins</td><td class="neg">−1</td><td class="pos">+2/3</td></tr>
      <tr><td>RAISE</td><td>FOLD</td><td>Bot forfeits, you win</td><td class="pos">+3</td><td class="neg">−1</td></tr>
      <tr><td>CALL</td><td>CALL</td><td>Showdown (winner ±2)</td><td>±2</td><td>±2</td></tr>
      <tr><td>RAISE</td><td>CALL</td><td>You win +3, lose −3</td><td>±3</td><td>±2</td></tr>
      <tr><td>CALL</td><td>RAISE</td><td>You win +2, lose −2</td><td>±2</td><td>±3</td></tr>
      <tr><td>RAISE</td><td>RAISE</td><td>High-risk showdown ±3</td><td>±3</td><td>±3</td></tr>
    </table>
  </div>

  <div class="setup-card" style="text-align:center;">
    <h2 style="justify-content:center;">⚙️ Game Setup</h2>
    <div class="rounds-selector">
      <label>Number of Rounds:</label>
      <input type="number" class="rounds-input" id="roundsInput" value="10" min="1" max="100">
    </div>
    <button class="btn btn-gold" onclick="playClick(); startGame()">Deal Me In ♠</button>
  </div>
</div>

<!-- ── GAME SCREEN ── -->
<div id="game" class="screen">
  <div class="scoreboard">
    <div class="score-block">
      <div class="score-label">You</div>
      <div class="score-value" id="humanScore">0</div>
    </div>
    <div class="round-info">
      Round <strong id="roundNum">1</strong> of <strong id="totalRounds">10</strong>
      <br><span id="roundStatus">Make your move</span>
    </div>
    <div class="score-block">
      <div class="score-label">Bot</div>
      <div class="score-value" id="botScore">0</div>
    </div>
  </div>

  <div class="table-area">
    <!-- BOT ZONE -->
    <div class="player-zone">
      <div class="zone-label">🤖 Bot's Hand (hidden)</div>
      <div class="cards-row">
        <div class="card hidden-card" id="botCard1">
          <div class="hidden-pattern">
            <span></span><span></span><span></span>
            <span></span><span></span><span></span>
            <span></span><span></span><span></span>
          </div>
        </div>
        <div class="card hidden-card" id="botCard2">
          <div class="hidden-pattern">
            <span></span><span></span><span></span>
