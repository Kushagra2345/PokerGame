<script>
// ─────────────────────────────────────────────
// AUDIO ENGINE — Web Audio API, no file deps
// ─────────────────────────────────────────────
let audioCtx = null;
let soundEnabled = true;

function getAudioCtx() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') audioCtx.resume();
  return audioCtx;
}

function toggleSound() {
  soundEnabled = !soundEnabled;
  const btn = document.getElementById('soundToggle');
  btn.textContent = soundEnabled ? '🔊' : '🔇';
  btn.classList.toggle('muted', !soundEnabled);
}

// Short, snappy click — soft high-pitched tick
function playClick() {
  if (!soundEnabled) return;
  try {
    const ctx = getAudioCtx();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.type = 'sine';
    osc.frequency.setValueAtTime(900, ctx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(600, ctx.currentTime + 0.04);
    gain.gain.setValueAtTime(0.18, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.07);
    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + 0.07);
  } catch(e) {}
}

// Win sound — bright rising chime arpeggio
function playWin() {
  if (!soundEnabled) return;
  try {
    const ctx = getAudioCtx();
    const notes = [523.25, 659.25, 783.99, 1046.50]; // C5 E5 G5 C6
    notes.forEach((freq, i) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.type = 'triangle';
      const t = ctx.currentTime + i * 0.1;
      osc.frequency.setValueAtTime(freq, t);
      gain.gain.setValueAtTime(0.0, t);
      gain.gain.linearRampToValueAtTime(0.22, t + 0.03);
      gain.gain.exponentialRampToValueAtTime(0.001, t + 0.35);
      osc.start(t);
      osc.stop(t + 0.35);
    });
  } catch(e) {}
}

// Loss / "FAAAH" sound — descending buzzy trombone slur
function playLoss() {
  if (!soundEnabled) return;
  try {
    const ctx = getAudioCtx();

    // Main trombone-slide oscillator
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    const dist = ctx.createWaveShaper();

    // Mild distortion for brassy buzz
    const curve = new Float32Array(256);
    for (let i = 0; i < 256; i++) {
      const x = (i * 2) / 256 - 1;
      curve[i] = (Math.PI + 200) * x / (Math.PI + 200 * Math.abs(x));
    }
    dist.curve = curve;

    osc.connect(dist);
    dist.connect(gain);
    gain.connect(ctx.destination);

    osc.type = 'sawtooth';
    const t = ctx.currentTime;
    // Classic "wah-waaah" descending pitch
    osc.frequency.setValueAtTime(370, t);
    osc.frequency.setValueAtTime(370, t + 0.08);
    osc.frequency.exponentialRampToValueAtTime(220, t + 0.22);
    osc.frequency.exponentialRampToValueAtTime(155, t + 0.55);
    osc.frequency.exponentialRampToValueAtTime(110, t + 0.85);

    gain.gain.setValueAtTime(0.0, t);
    gain.gain.linearRampToValueAtTime(0.3, t + 0.06);
    gain.gain.setValueAtTime(0.28, t + 0.22);
    gain.gain.linearRampToValueAtTime(0.18, t + 0.55);
    gain.gain.exponentialRampToValueAtTime(0.001, t + 0.95);

    osc.start(t);
    osc.stop(t + 0.95);

    // Second harmonic for extra buzz
    const osc2 = ctx.createOscillator();
    const gain2 = ctx.createGain();
    osc2.connect(gain2);
    gain2.connect(ctx.destination);
    osc2.type = 'sawtooth';
    osc2.frequency.setValueAtTime(185, t);
    osc2.frequency.exponentialRampToValueAtTime(78, t + 0.85);
    gain2.gain.setValueAtTime(0.0, t);
    gain2.gain.linearRampToValueAtTime(0.12, t + 0.06);
    gain2.gain.exponentialRampToValueAtTime(0.001, t + 0.9);
    osc2.start(t);
    osc2.stop(t + 0.9);
  } catch(e) {}
}

// Card deal sound — light soft thud
function playDeal() {
  if (!soundEnabled) return;
  try {
    const ctx = getAudioCtx();
    const bufSize = ctx.sampleRate * 0.06;
    const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
    const data = buf.getChannelData(0);
    for (let i = 0; i < bufSize; i++) {
      data[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / bufSize, 3) * 0.4;
    }
    const src = ctx.createBufferSource();
    const gain = ctx.createGain();
    const filter = ctx.createBiquadFilter();
    filter.type = 'lowpass';
    filter.frequency.value = 600;
    src.buffer = buf;
    src.connect(filter);
    filter.connect(gain);
    gain.connect(ctx.destination);
    gain.gain.setValueAtTime(0.7, ctx.currentTime);
    src.start(ctx.currentTime);
  } catch(e) {}
}

// Tie sound — neutral two-tone
function playTie() {
  if (!soundEnabled) return;
  try {
    const ctx = getAudioCtx();
    [440, 440].forEach((freq, i) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.type = 'sine';
      const t = ctx.currentTime + i * 0.18;
      osc.frequency.setValueAtTime(freq, t);
      gain.gain.setValueAtTime(0.15, t);
      gain.gain.exponentialRampToValueAtTime(0.001, t + 0.22);
      osc.start(t);
      osc.stop(t + 0.22);
    });
  } catch(e) {}
}

// ─────────────────────────────────────────────
// CARD ENGINE (mirrors final_bot.py logic)
// ─────────────────────────────────────────────
const RANKS = "23456789TJQKA";
const SUITS = "SHDC";
const RANK_VALUE = {};
RANKS.split('').forEach((r, i) => RANK_VALUE[r] = i + 2);
const SUIT_SYMBOL = { S: '♠', H: '♥', D: '♦', C: '♣' };
const SUIT_COLOR  = { S: 'black', H: 'red', D: 'red', C: 'black' };
const RANK_DISPLAY = { T: '10', J: 'J', Q: 'Q', K: 'K', A: 'A' };

function getDeck() {
  const deck = [];
  for (const r of RANKS) for (const s of SUITS) deck.push(r + s);
  return deck;
}
function shuffle(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}
function parseCard(c) { return { rank: RANK_VALUE[c[0]], suit: c[1], raw: c }; }
function rankDisplay(r) { return RANK_DISPLAY[r] || r; }

function isStraight(rankVals) {
  const r = [...rankVals].sort((a,b) => a - b);
  if (r[0]+1 === r[1] && r[1]+1 === r[2]) return { is: true, high: r[2] };
  if (new Set(r).size === 3 && r.includes(14) && r.includes(2) && r.includes(3)) return { is: true, high: 3 };
  return { is: false, high: 0 };
}

function evaluateHand(cards) {
  const parsed = cards.map(parseCard);
  const ranks = parsed.map(c => c.rank);
  const suits = parsed.map(c => c.suit);
  const ranksDesc = [...ranks].sort((a,b) => b - a);
  const counts = {};
  ranks.forEach(r => counts[r] = (counts[r] || 0) + 1);
  const isFlush = new Set(suits).size === 1;
  const { is: isSt, high: stHigh } = isStraight(ranks);
  const vals = Object.values(counts);

  if (isFlush && isSt)  return { cat: 5, name: 'Straight Flush', tiebreak: [stHigh] };
  if (vals.includes(3)) return { cat: 4, name: 'Three of a Kind', tiebreak: [+Object.keys(counts).find(k => counts[k]===3)] };
  if (isSt)             return { cat: 3, name: 'Straight',        tiebreak: [stHigh] };
  if (isFlush)          return { cat: 2, name: 'Flush',           tiebreak: ranksDesc };
  if (vals.includes(2)) {
    const pair = +Object.keys(counts).find(k => counts[k]===2);
    const kick = +Object.keys(counts).find(k => counts[k]===1);
    return { cat: 1, name: 'Pair', tiebreak: [pair, kick] };
  }
  return { cat: 0, name: 'High Card', tiebreak: ranksDesc };
}

function compareHands(h1, h2) {
  if (h1.cat !== h2.cat) return h1.cat > h2.cat ? 1 : -1;
  for (let i = 0; i < Math.max(h1.tiebreak.length, h2.tiebreak.length); i++) {
    const a = h1.tiebreak[i] || 0, b = h2.tiebreak[i] || 0;
    if (a !== b) return a > b ? 1 : -1;
  }
  return 0;
}

// ─────────────────────────────────────────────
// BOT LOGIC
// ─────────────────────────────────────────────
function botGetHighCardAction(hole, tableCard) {
  const tableRank = RANK_VALUE[tableCard[0]];
  const holeRanks = hole.map(c => RANK_VALUE[c[0]]);
  const maxHole = Math.max(...holeRanks);

  if (tableRank === 14) { return maxHole >= 12 ? 'RAISE' : maxHole >= 9 ? 'CALL' : 'FOLD'; }
  if (tableRank === 13) { return maxHole >= 12 ? 'RAISE' : maxHole >= 9 ? 'CALL' : 'FOLD'; }
  if (tableRank === 12) { return maxHole >= 13 ? 'RAISE' : maxHole >= 9 ? 'CALL' : 'FOLD'; }
  if (tableRank === 11) { return maxHole >= 13 ? 'RAISE' : maxHole >= 9 ? 'CALL' : 'FOLD'; }
  if (tableRank === 10) { return maxHole >= 13 ? 'RAISE' : maxHole >= 9 ? 'CALL' : 'FOLD'; }
  if (tableRank === 9)  { return maxHole >= 13 ? 'RAISE' : maxHole >= 10 ? 'CALL' : 'FOLD'; }
  if (tableRank >= 5)   { return maxHole >= 13 ? 'RAISE' : maxHole >= 11 ? 'CALL' : 'FOLD'; }
  return maxHole >= 13 ? 'RAISE' : maxHole >= 10 ? 'CALL' : 'FOLD';
}

function botDecide(hole, tableCard) {
  const allCards = [...hole, tableCard];
  const ev = evaluateHand(allCards);
  if (ev.cat >= 1) return 'RAISE';
  return botGetHighCardAction(hole, tableCard);
}

// ─────────────────────────────────────────────
// SCORING
// ─────────────────────────────────────────────
function calculateScore(act1, act2, winner) {
  if (act1 === 'FOLD' && act2 === 'FOLD') return [0, 0];
  if (act1 === 'FOLD') return [-1, act2 === 'CALL' ? 2 : 3];
  if (act2 === 'FOLD') return [act1 === 'CALL' ? 2 : 3, -1];
  if (winner === 0) return [0, 0];
  const wm = winner === 1 ? 1 : -1;
  if (act1 === 'CALL' && act2 === 'CALL') return [2*wm, -2*wm];
  if (act1 === 'RAISE' && act2 === 'RAISE') return [3*wm, -3*wm];
  if (act1 === 'RAISE' && act2 === 'CALL') return winner===1 ? [3,-2] : [-3,2];
  if (act1 === 'CALL'  && act2 === 'RAISE') return winner===1 ? [2,-3] : [-2,3];
  return [0, 0];
}

// ─────────────────────────────────────────────
// GAME STATE
// ─────────────────────────────────────────────
let state = {
  humanScore: 0,
  botScore: 0,
  round: 0,
  totalRounds: 10,
  humanHole: [],
  botHole: [],
  community: '',
  humanEv: null,
  botEv: null,
  roundDone: false
};

function startGame() {
  const n = parseInt(document.getElementById('roundsInput').value);
  if (isNaN(n) || n < 1) { showToast('Please enter a valid round count'); return; }
  state.humanScore = 0;
  state.botScore = 0;
  state.round = 0;
  state.totalRounds = n;
  showScreen('game');
  dealRound();
}

function dealRound() {
  state.round++;
  state.roundDone = false;

  document.getElementById('roundNum').textContent = state.round;
  document.getElementById('totalRounds').textContent = state.totalRounds;
  document.getElementById('roundStatus').textContent = 'Make your move';
  updateScoreDisplay();

  const deck = shuffle(getDeck());
  state.humanHole = [deck.pop(), deck.pop()];
  state.botHole   = [deck.pop(), deck.pop()];
  state.community = deck.pop();

  playDeal();

  renderCard(state.community, 'commRank','commSuit','commCenter','commRankB','commSuitB','communityCard');
  renderCard(state.humanHole[0], 'h1Rank','h1Suit','h1Center','h1RankB','h1SuitB','humanCard1');
  renderCard(state.humanHole[1], 'h2Rank','h2Suit','h2Center','h2RankB','h2SuitB','humanCard2');

  state.humanEv = evaluateHand([...state.humanHole, state.community]);
  state.botEv   = evaluateHand([...state.botHole, state.community]);

  ['botCard1','botCard2'].forEach(id => {
    document.getElementById(id).innerHTML = `<div class="hidden-pattern">${'<span></span>'.repeat(9)}</div>`;
    document.getElementById(id).className = 'card hidden-card';
  });

  document.getElementById('resultPanel').classList.remove('show');
  document.getElementById('actionArea').style.display = 'flex';
  setActionButtonsEnabled(true);
}

function renderCard(raw, rankId, suitId, centerId, rankBId, suitBId, cardId) {
  const r = raw[0], s = raw[1];
  const rDisp = rankDisplay(r);
  const sSym  = SUIT_SYMBOL[s];
  const isRed = SUIT_COLOR[s] === 'red';
  const el = document.getElementById(cardId);
  if (el) {
    el.className = 'card revealed ' + (isRed ? 'red-card' : 'black-card');
    if (cardId === 'communityCard') el.classList.add('community-card');
  }
  document.getElementById(rankId).textContent  = rDisp;
  document.getElementById(suitId).textContent  = sSym;
  document.getElementById(centerId).textContent = sSym;
  document.getElementById(rankBId).textContent  = rDisp;
  document.getElementById(suitBId).textContent  = sSym;
}

function renderSmallCard(raw) {
  const r = raw[0], s = raw[1];
  const rDisp = rankDisplay(r);
  const sSym  = SUIT_SYMBOL[s];
  const isRed = SUIT_COLOR[s] === 'red';
  return `<div class="card ${isRed?'red-card':'black-card'} revealed" style="width:60px;height:85px;padding:4px 6px;font-size:0.85rem;">
    <div class="card-corner"><div class="card-rank" style="font-size:0.8rem;">${rDisp}</div><div class="card-suit" style="font-size:0.6rem;">${sSym}</div></div>
    <div class="card-center" style="font-size:1.4rem;">${sSym}</div>
    <div class="card-corner bottom"><div class="card-rank" style="font-size:0.8rem;">${rDisp}</div><div class="card-suit" style="font-size:0.6rem;">${sSym}</div></div>
  </div>`;
}

function setActionButtonsEnabled(on) {
  document.querySelectorAll('.btn-action').forEach(b => b.disabled = !on);
}

function playerAction(humanAct) {
  if (state.roundDone) return;
  state.roundDone = true;
  setActionButtonsEnabled(false);
  document.getElementById('actionArea').style.display = 'none';

  const botAct = botDecide(state.botHole, state.community);
  const winner = compareHands(state.humanEv, state.botEv);
  const [dHuman, dBot] = calculateScore(humanAct, botAct, winner);

  state.humanScore += dHuman;
  state.botScore   += dBot;

  // Play outcome sound
  if (dHuman > 0) {
    playWin();
  } else if (dHuman < 0) {
    playLoss();
  } else {
    playTie();
  }

  revealBotCard(state.botHole[0], 'botCard1');
  revealBotCard(state.botHole[1], 'botCard2');

  showResult(humanAct, botAct, winner, dHuman, dBot);
  updateScoreDisplay();

  if (state.round >= state.totalRounds) {
    document.getElementById('nextBtn').textContent = 'See Final Results →';
    document.getElementById('nextBtn').onclick = () => { playClick(); endGame(); };
  } else {
    document.getElementById('nextBtn').textContent = 'Next Round →';
    document.getElementById('nextBtn').onclick = () => { playClick(); nextRound(); };
  }
}

function revealBotCard(raw, cardId) {
  const r = raw[0], s = raw[1];
  const rDisp = rankDisplay(r);
  const sSym  = SUIT_SYMBOL[s];
  const isRed = SUIT_COLOR[s] === 'red';
  const el = document.getElementById(cardId);
  el.className = 'card revealed ' + (isRed ? 'red-card' : 'black-card');
  el.innerHTML = `
    <div class="card-corner"><div class="card-rank">${rDisp}</div><div class="card-suit">${sSym}</div></div>
    <div class="card-center">${sSym}</div>
    <div class="card-corner bottom"><div class="card-rank">${rDisp}</div><div class="card-suit">${sSym}</div></div>
  `;
}

function showResult(humanAct, botAct, winner, dHuman, dBot) {
  const panel = document.getElementById('resultPanel');
  const headline = document.getElementById('resultHeadline');
  const details  = document.getElementById('resultDetails');
  const botReveal = document.getElementById('botReveal');

  let headText = '', headClass = '';
  if (humanAct === 'FOLD' && botAct === 'FOLD') { headText = 'Both Folded'; headClass = 'tie'; }
  else if (humanAct === 'FOLD') { headText = 'You Folded'; headClass = 'lose'; }
  else if (botAct === 'FOLD')   { headText = 'Bot Folded — You Win!'; headClass = 'win'; }
  else if (winner === 1)  { headText = '🏆 You Win!'; headClass = 'win'; }
  else if (winner === -1) { headText = '🤖 Bot Wins'; headClass = 'lose'; }
  else { headText = '🤝 Tie'; headClass = 'tie'; }

  headline.textContent = headText;
  headline.className = 'result-headline ' + headClass;

  botReveal.innerHTML = state.botHole.map(c => renderSmallCard(c)).join('');

  details.innerHTML = `
    You <strong style="color:var(--gold)">${humanAct}</strong> · Bot <strong style="color:var(--gold)">${botAct}</strong><br>
    Your hand: <span class="hand-name">${state.humanEv.name}</span> · Bot hand: <span class="hand-name">${state.botEv.name}</span>
  `;

  const dh = document.getElementById('deltaHuman');
  const db = document.getElementById('deltaBot');
  dh.textContent = (dHuman > 0 ? '+' : '') + dHuman;
  dh.className   = 'delta-val ' + (dHuman > 0 ? 'pos' : dHuman < 0 ? 'neg' : 'zero');
  db.textContent = (dBot > 0 ? '+' : '') + dBot;
  db.className   = 'delta-val ' + (dBot > 0 ? 'pos' : dBot < 0 ? 'neg' : 'zero');

  panel.classList.add('show');
}

function updateScoreDisplay() {
  const hs = document.getElementById('humanScore');
  const bs = document.getElementById('botScore');
  hs.textContent = state.humanScore;
  bs.textContent = state.botScore;
  hs.className = 'score-value ' + (state.humanScore > 0 ? 'positive' : state.humanScore < 0 ? 'negative' : '');
  bs.className = 'score-value ' + (state.botScore > 0 ? 'positive' : state.botScore < 0 ? 'negative' : '');
}

function nextRound() {
  document.getElementById('resultPanel').classList.remove('show');
  document.getElementById('actionArea').style.display = 'flex';
  dealRound();
}

function endGame() {
  hideQuitModal();
  document.getElementById('endHumanScore').textContent = state.humanScore;
  document.getElementById('endBotScore').textContent   = state.botScore;

  let trophy = '🤝', title = "It's a Draw!";
  if (state.humanScore > state.botScore)      { trophy = '🏆'; title = 'You Win!'; }
  else if (state.botScore > state.humanScore) { trophy = '🤖'; title = 'Bot Wins!'; }
  document.getElementById('endTrophy').textContent = trophy;
  document.getElementById('endTitle').textContent  = title;
  document.getElementById('endSubtitle').textContent = `After ${state.round} round${state.round!==1?'s':''}`;

  if (state.humanScore > state.botScore) playWin();
  else if (state.botScore > state.humanScore) playLoss();
  else playTie();

  showScreen('end');
}

function backToSetup() { showScreen('setup'); }

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function showQuitModal() { document.getElementById('quitModal').classList.add('show'); }
function hideQuitModal() { document.getElementById('quitModal').classList.remove('show'); }

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}
</script>
</body>
